{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nekora",
  "version": "0.1.0",
  "identifier": "app.nekora.core",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nekora",
        "width": 1160,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/Nekora.ico",
      "icons/Nekora.png"
    ],
    "copyright": "Copyright © 2026 Ziyi LIU"
  }
}
